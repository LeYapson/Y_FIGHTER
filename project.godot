; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Y_FIGHTER"
run/main_scene="res://Stages/test stage 2d.tscn"
config/features=PackedStringArray("4.0", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=720
window/size/window_height_override=480

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/goshapes/plugin.cfg")

[layer_names]

2d_physics/layer_1="player"
3d_physics/layer_1="player"
2d_physics/layer_2="Walls"
3d_physics/layer_2="Walls"
2d_physics/layer_3="Platforms"
2d_physics/layer_4="Ledge"
2d_physics/layer_5="blastzones"

[rendering]

textures/canvas_textures/default_texture_filter=0
